# ============================================================================
# Recovery Portal — environment configuration
# Copy to .env.local and edit. Never commit .env.local to git.
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED secrets
# Run ./scripts/init-secrets.sh to generate these automatically.
# ----------------------------------------------------------------------------

# 32-byte hex string for signing session JWTs.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# 32-byte hex string for encrypting TOTP secrets at rest.
# LOSING THIS LOCKS EVERY 2FA-ENABLED USER OUT — back it up alongside your DB.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Cookies
# ----------------------------------------------------------------------------

# Set to "true" when serving over HTTPS in production.
# This makes session cookies require a secure connection.
COOKIE_SECURE=false

# ----------------------------------------------------------------------------
# Data storage
# ----------------------------------------------------------------------------

# Where the SQLite database, uploaded videos, and branding assets live.
# Default: ./data
# In Docker, this is mapped to a volume by docker-compose.yml.
# DATA_DIR=./data

# ----------------------------------------------------------------------------
# Web Push notifications (optional)
# Generate keys: npx web-push generate-vapid-keys
# ----------------------------------------------------------------------------

# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourclinic.com.au

# Expose the public key to the client-side push registration code.
# Must match VAPID_PUBLIC_KEY above.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ----------------------------------------------------------------------------
# Node / Next.js
# ----------------------------------------------------------------------------

# NODE_ENV=production
# PORT=3000
